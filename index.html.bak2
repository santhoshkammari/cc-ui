let pendingTheme = null;

function applyTheme(name) {
  const t = THEMES[name]; if (!t) return;
  const root = document.documentElement;
  for (const [k, v] of Object.entries(t)) {
    if (k !== 'glass') root.style.setProperty('--' + k, v);
  }
  document.body.classList.toggle('glass-theme', !!t.glass);
  document.body.style.background = (name.startsWith('macOS') || name.startsWith('Claude')) && !t.glass
    ? `radial-gradient(ellipse at 30% 0%, color-mix(in srgb, ${t.orange} 8%, ${t.bg0}) 0%, ${t.bg0} 60%)` : '';
  localStorage.setItem('theme', name);
}

function buildThemeGrid() {
  const grid = document.getElementById('theme-grid');
  const current = localStorage.getItem('theme') || 'GitHub Dark';
  grid.innerHTML = Object.entries(THEMES).map(([name, t]) => {
    const bg = t.glass ? 'linear-gradient(135deg,#1a1a2e,#0a0a0f)' : t.bg1;
    return `<div class="theme-swatch${name===current?' selected':''}" data-theme="${name}">
      <div class="swatch-preview" style="background:${bg}">
        <span style="background:${t.blue}"></span><span style="background:${t.green}"></span>
        <span style="background:${t.orange}"></span><span style="background:${t.red}"></span>
      </div><div class="swatch-name">${name}</div></div>`;
  }).join('');
  grid.querySelectorAll('.theme-swatch').forEach(el => {
    el.addEventListener('click', () => {
      grid.querySelectorAll('.theme-swatch').forEach(s => s.classList.remove('selected'));
      el.classList.add('selected');
      pendingTheme = el.dataset.theme;
    });
  });
}

function openSettings() {
  pendingTheme = localStorage.getItem('theme') || 'GitHub Dark';
  buildThemeGrid();
  document.getElementById('s-vllm-ip').value = localStorage.getItem('vllm_ip') || 'localhost';
  document.getElementById('s-vllm-port').value = localStorage.getItem('vllm_port') || '8000';
  document.getElementById('s-vllm-model').value = localStorage.getItem('vllm_model') || '/home/ng6309/datascience/santhosh/models/qwen3.5-9b';
  document.getElementById('settings-overlay').classList.add('open');
}

document.getElementById('settings-cancel').addEventListener('click', () => {
  document.getElementById('settings-overlay').classList.remove('open');
});
document.getElementById('settings-apply').addEventListener('click', () => {
  if (pendingTheme) applyTheme(pendingTheme);
  localStorage.setItem('vllm_ip', document.getElementById('s-vllm-ip').value.trim() || 'localhost');
  localStorage.setItem('vllm_port', document.getElementById('s-vllm-port').value.trim() || '8000');
  localStorage.setItem('vllm_model', document.getElementById('s-vllm-model').value.trim() || '');
  document.getElementById('settings-overlay').classList.remove('open');
  toast('Settings saved', 'success');
});
document.getElementById('settings-overlay').addEventListener('click', e => {
  if (e.target === document.getElementById('settings-overlay'))
    document.getElementById('settings-overlay').classList.remove('open');
});

// ── Event Handlers ────────────────────────────────────────────────
const promptEl = document.getElementById('cb-prompt');
promptEl.addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 200) + 'px';
});
promptEl.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); handleSend(); }
});

// Ctrl+U to attach files
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'u') {
    e.preventDefault();
    document.getElementById('cb-file-picker').click();
  }
});

// CWD autocomplete with dropdown
const cwdEl = document.getElementById('cb-cwd');
const cwdDrop = document.getElementById('cwd-dropdown');
let cwdTimeout, cwdSuggestions = [], cwdSelectedIdx = -1;

async function cwdSearch(query) {
  if (query.length < 1) { cwdHide(); return; }
  try {
    cwdSuggestions = await api('GET', `/suggest?path=${encodeURIComponent(query)}`);
    if (cwdSuggestions.length) {
      cwdSelectedIdx = -1;
      cwdDrop.innerHTML = cwdSuggestions.map((p, i) => {
        const parts = p.split('/');
        const name = parts[parts.length - 1] || parts[parts.length - 2] || p;
        const short = parts.slice(-3).join('/');
        return `<div class="cwd-item" data-idx="${i}" onmousedown="cwdSelect(${i})">
          <span class="cwd-icon">📁</span>
          <span class="cwd-path">${esc(name)}</span>
          <span class="cwd-short">${esc(short)}</span>
        </div>`;
      }).join('');
      cwdDrop.classList.add('open');
    } else {
      cwdHide();
    }
  } catch(e) { cwdHide(); }
}

function cwdSelect(idx) {
  const path = cwdSuggestions[idx];
  if (path) {
    cwdEl.value = path + '/';
    cwdHide();
    cwdEl.focus();
    // Trigger search for subdirs
    clearTimeout(cwdTimeout);
    cwdTimeout = setTimeout(() => cwdSearch(path + '/'), 200);
  }
}

function cwdHide() {
  cwdDrop.classList.remove('open');
  cwdSuggestions = [];
  cwdSelectedIdx = -1;
}

function cwdHighlight(idx) {
  cwdSelectedIdx = idx;
  cwdDrop.querySelectorAll('.cwd-item').forEach((el, i) => {
    el.style.background = i === idx ? 'var(--bg2)' : '';
    el.style.color = i === idx ? 'var(--tx0)' : '';
  });
}

cwdEl.addEventListener('input', function() {
  clearTimeout(cwdTimeout);
  cwdTimeout = setTimeout(() => cwdSearch(this.value.trim()), 250);
});

cwdEl.addEventListener('keydown', function(e) {
  if (!cwdDrop.classList.contains('open')) {
    if (e.key === 'Tab') {
      e.preventDefault();
      cwdSearch(this.value.trim());
    }
    return;
  }
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    cwdHighlight(Math.min(cwdSelectedIdx + 1, cwdSuggestions.length - 1));
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    cwdHighlight(Math.max(cwdSelectedIdx - 1, 0));
  } else if (e.key === 'Enter' && cwdSelectedIdx >= 0) {
    e.preventDefault();
    cwdSelect(cwdSelectedIdx);
  } else if (e.key === 'Tab') {
    e.preventDefault();
    if (cwdSelectedIdx >= 0) cwdSelect(cwdSelectedIdx);
    else if (cwdSuggestions.length === 1) cwdSelect(0);
    else if (cwdSuggestions.length > 1) cwdHighlight(0);
  } else if (e.key === 'Escape') {
    cwdHide();
  }
});

cwdEl.addEventListener('blur', () => setTimeout(cwdHide, 200));
cwdEl.addEventListener('focus', function() {
  if (this.value.trim().length >= 1) cwdSearch(this.value.trim());
});

document.getElementById('ws-path-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') confirmAddWs();
  if (e.key === 'Escape') closeWsDialog();
});

document.getElementById('ws-dialog').addEventListener('click', function(e) {
  if (e.target === this) closeWsDialog();
});

// ── Polling ───────────────────────────────────────────────────────
async function poll() {
  await refreshTasks();
  if (view === 'detail' && activeTaskId) {
    await loadConversation(activeTaskId);
  }
  refreshGit();
}

// ── Resizable Panels ──────────────────────────────────────────────
(function initResizablePanels() {
  function setupResize(handleId, panelId, side) {
    const handle = document.getElementById(handleId);
    const panel = document.getElementById(panelId);
    if (!handle || !panel) return;
    let startX, startW;
    handle.addEventListener('mousedown', e => {
      e.preventDefault();
      startX = e.clientX;
      startW = panel.offsetWidth;
      handle.classList.add('active');
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';
      const onMove = ev => {
        const dx = ev.clientX - startX;
        const newW = Math.max(160, Math.min(500, side === 'left' ? startW + dx : startW - dx));
        panel.style.width = newW + 'px';
        panel.style.minWidth = newW + 'px';
      };
      const onUp = () => {
        handle.classList.remove('active');
        document.body.style.cursor = '';
        document.body.style.userSelect = '';
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
      };
      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
  }
  setupResize('left-resize', 'left-panel', 'left');
  setupResize('right-resize', 'right-panel', 'right');
})();

// ── Init ──────────────────────────────────────────────────────────
applyTheme(localStorage.getItem('theme') || 'GitHub Dark');
showDashboard();
refreshWorkspaces();
refreshTasks();
setInterval(poll, 2500);
</script>
